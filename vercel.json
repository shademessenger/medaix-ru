{
  "rewrites": [
    {
      "source": "/ai/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/ai/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/ai",
      "destination": "/index.html"
    },
    {
      "source": "/ai/",
      "destination": "/index.html"
    }
  ]
}
